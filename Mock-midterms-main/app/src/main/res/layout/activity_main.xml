<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:windowBackground">

    <!-- Secondary display: shows operator/operand state -->
    <TextView
        android:id="@+id/tvSecondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:text=""
        android:textColor="?android:textColorSecondary"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Primary display: current number/result -->
    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:text="0"
        android:textColor="?android:textColor"
        android:textSize="52sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="start"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSecondary" />

    <!-- Button grid -->
    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDisplay">

        <!-- Row 1: C, +/-, %, ÷ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/CalcButton.Function"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="@string/btn_clear" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNegate"
            style="@style/CalcButton.Function"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="@string/btn_negate" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPercent"
            style="@style/CalcButton.Function"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="@string/btn_percent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDivide"
            style="@style/CalcButton.Operator"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="@string/btn_divide" />

        <!-- Row 2: 7, 8, 9, × -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn7"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="7" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn8"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn9"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="9" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMultiply"
            style="@style/CalcButton.Operator"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="@string/btn_multiply" />

        <!-- Row 3: 4, 5, 6, − -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn4"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn5"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn6"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="6" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubtract"
            style="@style/CalcButton.Operator"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="@string/btn_subtract" />

        <!-- Row 4: 1, 2, 3, + -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn1"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn2"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn3"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            style="@style/CalcButton.Operator"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="@string/btn_add" />

        <!-- Row 5: 0 (span 2), ., = -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn0"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnSpan="2"
            android:layout_columnWeight="2"
            android:gravity="center_vertical|start"
            android:paddingStart="28dp"
            android:text="0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecimal"
            style="@style/CalcButton.Number"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="@string/btn_decimal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEquals"
            style="@style/CalcButton.Operator"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:text="@string/btn_equals" />

    </GridLayout>

    <!-- Custom Operator button: × 3.31 (ID) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button"
        style="@style/CalcButton.Operator"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="6dp"
        android:backgroundTint="@color/custom_operator_color"
        android:text="@string/btn_custom_op"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/gridLayout" />

    <!-- Toggle Theme button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggleTheme"
        style="@style/CalcButton.Function"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="6dp"
        android:text="@string/btn_toggle_theme"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button" />

    <!-- History label -->
    <TextView
        android:id="@+id/tvHistoryLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:text="@string/history_label"
        android:textColor="?android:textColor"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnToggleTheme" />

    <!-- ScrollView containing RecyclerView for history (bonus) -->
    <ScrollView
        android:id="@+id/scrollViewHistory"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHistoryLabel">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="16dp"
            tools:itemCount="3"
            tools:listitem="@layout/item_history" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
